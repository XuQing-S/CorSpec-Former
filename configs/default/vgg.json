{
  "description": "1D VGG-style baseline for LIBS metal classification.",
  "experiment": {
    "output_root": "experiments/dl",
    "run_name": "vgg_baseline"
  },
  "model": "vgg",
  "model_params": {
    "input_channels": 1,
    "channels_per_block": [[64, 64], [128, 128], [256, 256, 256], [512, 512, 512]],
    "kernel_size": 3,
    "pool_size": 2,
    "classifier_hidden_dim": 256,
    "dropout": 0.4
  },
  "optimization": {
    "learning_rate": 0.0004,
    "weight_decay": 0.0001,
    "lr_scheduler": "cosine",
    "lr_factor": 0.7,
    "lr_patience": 8,
    "min_lr": 0.00002
  }
}
