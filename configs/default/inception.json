{
  "description": "1D Inception-style baseline for LIBS metal classification.",
  "experiment": {
    "output_root": "experiments/dl",
    "run_name": "inception_baseline"
  },
  "model": "inception",
  "model_params": {
    "input_channels": 1,
    "stem_channels": 32,
    "branch_channels": [[32, 32, 32, 32], [64, 64, 64, 64], [96, 96, 96, 96]],
    "kernel_sizes": [5, 9],
    "pool_sizes": [2, 2, null],
    "dropout": 0.35
  },
  "optimization": {
    "learning_rate": 0.0004,
    "weight_decay": 0.0001,
    "lr_scheduler": "cosine",
    "lr_factor": 0.7,
    "lr_patience": 8,
    "min_lr": 0.00002
  }
}
