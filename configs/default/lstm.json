{
  "description": "Conv-LSTM baseline for LIBS metal classification.",
  "experiment": {
    "output_root": "experiments/dl",
    "run_name": "lstm_31_16_256_2_mean_0.4"
  },
  "model": "lstm",
  "model_params": {
    "input_channels": 1,
    "conv_channels": 128,
    "conv_kernel_size": 31,
    "conv_stride": 16,
    "hidden_size": 256,
    "num_layers": 2,
    "bidirectional": true,
    "pooling": "mean",
    "dropout": 0.4
  },
  "optimization": {
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "lr_scheduler": "cosine",
    "lr_factor": 0.7,
    "lr_patience": 8,
    "min_lr": 1e-05
  }
}
